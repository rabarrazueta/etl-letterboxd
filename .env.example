# .env.example
# Copia este archivo a '.env' y llena tus credenciales reales.

# --- GCP Credentials (Para uso local/testing) ---
# Ruta al archivo JSON de tu Service Account local (no usar en Databricks)
GOOGLE_APPLICATION_CREDENTIALS="./secrets/gcp-service-account.json"
GCP_PROJECT_ID="tu-proyecto-gcp"

# --- APIs Externas ---
TMDB_API_KEY="tu_api_key_aqui"
# SPOTIFY_CLIENT_ID="para_el_proyecto_2"
# SPOTIFY_CLIENT_SECRET="para_el_proyecto_2"

# --- Configuración de Storage (fsspec) ---
# 'gcs' para Fase 1 (GCP), 'local' para Fase 2 (Docker/DigitalOcean)
STORAGE_BACKEND="gcs" 
GCS_BUCKET_NAME="tu-datalake-bucket"
LOCAL_STORAGE_PATH="./data"

# --- Base de Datos (Fase 2 - PostgreSQL) ---
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="super_secret_password"
POSTGRES_DB="portfolio_db"
POSTGRES_PORT="5432"

# --- n8n (Fase 1 y 2) ---
N8N_WEBHOOK_URL="http://tu-servidor-digitalocean:5678/webhook/..."