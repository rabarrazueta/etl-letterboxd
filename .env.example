# .env.example
# Copia este archivo a '.env' solo para ejecuciones LOCALES (Fase 2 / testing).
# -----------------------------------------------------------------------------
# IMPORTANTE (Databricks / Fase 1):
# - Los notebooks en /databricks NO consumen este .env.
# - En Databricks la configuración entra por:
#   - Widgets del Job (project_id, bucket_name, bq_dataset, etc.)
#   - Databricks Secrets (Secret Scope) y/o GCP Secret Manager (ADC)
# - Recomendación para TMDB:
#   - Guardar secretId: tmdb-api-key en GCP Secret Manager (y dar permisos al SA del cluster)
#   - Opcionalmente, también crear un Secret Scope en Databricks y usar el widget `secret_scope`

# --- GCP Credentials (Solo local/testing, NO Databricks) ---
GOOGLE_APPLICATION_CREDENTIALS="./secrets/gcp-service-account.json"
GCP_PROJECT_ID="tu-proyecto-gcp"

# --- APIs Externas (Solo local/testing, NO Databricks) ---
TMDB_API_KEY="tu_api_key_aqui"

# --- Configuración de Storage (fsspec) ---
# Backend de storage para ejecución LOCAL (Fase 2 / módulos en /ingestion).
# En Databricks (Fase 1) se usa directamente gs:// y permisos del cluster (no este .env).
STORAGE_BACKEND="gcs"
GCS_BUCKET="tu-datalake-bucket"
LOCAL_STORAGE_PATH="./data"

# --- Base de Datos (Fase 2 - PostgreSQL) ---
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="super_secret_password"
POSTGRES_DB="portfolio_db"
POSTGRES_PORT="5432"

# --- n8n (Fase 1 y 2) ---
N8N_WEBHOOK_URL="http://tu-servidor-digitalocean:5678/webhook/..."